{
  "name": "@open-pets/desktop",
  "version": "2.1.1",
  "private": true,
  "description": "OpenPets tray-first desktop companion app.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alvinunreal/openpets.git",
    "directory": "apps/desktop"
  },
  "author": "OpenPets",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "dev": "pnpm build && electron .",
    "dev:plugins": "OPENPETS_DISABLE_PLUGIN_CATALOG=1 OPENPETS_DEV_PLUGIN_ROOTS=../../web/plugins/official pnpm dev",
    "dev:debug": "OPENPETS_LOG_LEVEL=debug OPENPETS_LOG_CONSOLE=1 pnpm dev",
    "package": "pnpm build && node scripts/clean-package-output.cjs && electron-builder",
    "package:dir": "pnpm build && node scripts/clean-package-output.cjs && electron-builder --dir && node dist/check-packaging-contract.js --output",
    "test": "node scripts/run-tests.mjs",
    "build:deps": "pnpm --filter @open-pets/desktop^... build",
    "clean:dist": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "test:build": "pnpm build:deps && tsc -p tsconfig.tests.json",
    "check": "pnpm typecheck && pnpm build && pnpm test",
    "typecheck": "pnpm build:deps && tsc --noEmit && tsc -p tsconfig.control-center.json --noEmit",
    "build": "pnpm clean:dist && pnpm build:deps && tsc && vite build --config vite.control-center.config.ts"
  },
  "devDependencies": {
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/node": "^25.6.2",
    "@types/yauzl": "2.10.3",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^42.0.0",
    "electron-builder": "^26.10.0",
    "typescript": "^6.0.3",
    "vite": "^7.2.6"
  },
  "dependencies": {
    "@open-pets/agent-events": "workspace:*",
    "@open-pets/claude": "workspace:*",
    "@open-pets/cli": "workspace:*",
    "@open-pets/cursor": "workspace:*",
    "@open-pets/mcp": "workspace:*",
    "@open-pets/opencode": "workspace:*",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "sharp": "^0.34.5",
    "yauzl": "3.3.0"
  }
}
